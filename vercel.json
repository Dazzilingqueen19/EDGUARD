{
  "version": 2,
  "buildCommand": "npm run build --prefix frontendnew && npm run build --prefix parent-web-app",
  "outputDirectory": "frontendnew/dist",
  "env": {
    "VERCEL_ENV": "production"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "api/index.py?path=:path*"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/parent/(.*)",
      "dest": "/parent-web-app/dist/$1"
    },
    {
      "src": "/parent(.*)",
      "dest": "/parent-web-app/dist/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/frontendnew/dist/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/frontendnew/dist/index.html"
    }
  ],
  "env": {
    "PYTHON_VERSION": "3.11"
  },
  "buildCommand": "npm run build --prefix frontendnew && npm run build --prefix parent-web-app"
}
