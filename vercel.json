{
  "version": 2,
  "builds": [
    {
      "src": "frontendnew/package.json",
      "use": "@vercel/static-build",
      "config": {
        "buildCommand": "npm install && npm run build",
        "outputDirectory": "dist"
      }
    },
    {
      "src": "parent-web-app/package.json",
      "use": "@vercel/static-build",
      "config": {
        "buildCommand": "npm install && npm run build",
        "outputDirectory": "dist"
      }
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "pythonVersion": "3.11",
        "requirementsFile": "vercel-requirements.txt"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/parent/(.*)",
      "dest": "/parent-web-app/dist/$1",
      "methods": ["GET", "HEAD"]
    },
    {
      "src": "/parent(.*)",
      "dest": "/parent-web-app/dist/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/frontendnew/dist/$1",
      "methods": ["GET", "HEAD"]
    },
    {
      "src": "(.*)",
      "dest": "/frontendnew/dist/index.html"
    }
  ]
}
